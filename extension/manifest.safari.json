{
    "manifest_version": 3,
    "name": "ScreenshotSafe",
    "version": "1.0.0",
    "description": "Capture and share screenshots privately via your ScreenshotSafe server.",
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "browser_specific_settings": {
        "safari": {
            "strict_min_version": "17.0"
        }
    }
}
